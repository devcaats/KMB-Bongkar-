# Port yang didengarkan bot (Railway otomatis set PORT, tidak perlu diubah)
PORT=3025
WHATSAPP_BOT_PORT=3025

# Direktori penyimpanan session WhatsApp
WHATSAPP_AUTH_DIR=storage/whatsapp-session

# Token keamanan API (isi dengan string acak yang kuat, wajib di production)
WHATSAPP_BOT_TOKEN=isi_dengan_token_rahasia_anda

# Level log: silent | info | debug
WHATSAPP_BOT_LOG_LEVEL=silent
